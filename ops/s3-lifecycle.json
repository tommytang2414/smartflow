{
  "Rules": [
    {
      "ID": "abort-incomplete-multipart-uploads",
      "Status": "Enabled",
      "Filter": {
        "Prefix": ""
      },
      "AbortIncompleteMultipartUpload": {
        "DaysAfterInitiation": 7
      }
    },
    {
      "ID": "live-db-version-retention",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "smartflow.db"
      },
      "NoncurrentVersionExpiration": {
        "NoncurrentDays": 30
      }
    },
    {
      "ID": "sec-beta-snapshot-version-retention",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "beta/sec-v2-shadow.db"
      },
      "NoncurrentVersionExpiration": {
        "NoncurrentDays": 30
      }
    },
    {
      "ID": "operational-backups-retention",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "backups/"
      },
      "Expiration": {
        "Days": 30
      },
      "NoncurrentVersionExpiration": {
        "NoncurrentDays": 7
      }
    },
    {
      "ID": "legacy-dated-backup-retention",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "20260721/"
      },
      "Expiration": {
        "Days": 30
      },
      "NoncurrentVersionExpiration": {
        "NoncurrentDays": 7
      }
    },
    {
      "ID": "short-alpha-retention",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "short-alpha/"
      },
      "Expiration": {
        "Days": 30
      },
      "NoncurrentVersionExpiration": {
        "NoncurrentDays": 7
      }
    }
  ]
}
